{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Todos OCaml",
  "version": "0.1.0",
  "identifier": "dev.todos-ocaml.desktop",
  "build": {
    "beforeBuildCommand": "npm --prefix web run build && opam exec -- dune build app/tauri_store.exe",
    "beforeDevCommand": "opam exec -- dune build app/tauri_store.exe && npm --prefix web run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web/tauri-dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Todos OCaml",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 780,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": {
      "../_build/default/app/tauri_store.exe": "tauri_store"
    }
  }
}
